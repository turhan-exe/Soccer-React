PORT=9090
HOST=0.0.0.0
NODE_ID=node-a
NODE_PUBLIC_IP=127.0.0.1
NODE_PRIVATE_IP=127.0.0.1
NODE_AGENT_SECRET=change-me
UNITY_SERVER_BINARY=C:\UnityProject\FHS\Builds\FHS.exe
UNITY_SERVER_WORKDIR=C:\UnityProject\FHS\Builds
ALLOCATABLE_PORTS=21001,21002,21003,21004,21005,21006,21007
DEFAULT_MAX_CLIENTS=2
AUTO_RELEASE_ON_EXIT=true
PROCESS_KILL_TIMEOUT_MS=6000
MATCH_HARD_TIMEOUT_MS=1800000
MATCH_MINUTE_HEARTBEAT_ENABLED=true
MATCH_MINUTE_CLOSE_THRESHOLD=90
MATCH_MINUTE_CLOSE_GRACE_MS=60000
MATCH_CONTROL_CALLBACK_BASE_URL=http://127.0.0.1:8080
MATCH_CONTROL_CALLBACK_TOKEN=change-me-match-control-callback-token
# Match runtime role for Unity process: server|host|client
UNITY_MATCH_ROLE=server
# Optional Unity callback override (recommended HTTPS endpoint for Unity lifecycle callbacks)
# If empty, node-agent callback URL is reused.
UNITY_MATCH_CONTROL_CALLBACK_URL=
# Optional Unity callback token override (falls back to MATCH_CONTROL_CALLBACK_TOKEN).
UNITY_MATCH_CONTROL_CALLBACK_TOKEN=
# Default false: suppress passing plain HTTP callback URL to Unity to avoid
# "Insecure connection not allowed" runtime exception.
UNITY_MATCH_CONTROL_CALLBACK_ALLOW_INSECURE_HTTP=false
NODE_AGENT_DEBUG_CHILD_LOGS=false
